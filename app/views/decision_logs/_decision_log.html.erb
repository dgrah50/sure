<%# locals: (decision_log:) %>

<%= turbo_frame_tag dom_id(decision_log), class: "block" do %>
  <div class="group p-4 hover:bg-subtle transition-colors">
    <div class="flex items-start gap-4">
      <%# Decision Type Icon %>
      <div class="shrink-0 mt-0.5">
        <% case decision_log.decision_type %>
        <% when "action_dismissed" %>
          <%= icon "x-circle", size: "md", class: "text-orange-500" %>
        <% when "recommendation_approved" %>
          <%= icon "check-circle-2", size: "md", class: "text-green-500" %>
        <% when "recommendation_rejected" %>
          <%= icon "ban", size: "md", class: "text-red-500" %>
        <% when "manual_override" %>
          <%= icon "shield-alert", size: "md", class: "text-blue-500" %>
        <% else %>
          <%= icon "file-text", size: "md", class: "text-secondary" %>
        <% end %>
      </div>

      <%# Content %>
      <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="flex items-center gap-2 flex-wrap">
              <h3 class="font-medium text-primary text-sm">
                <%= decision_log.decision_type.humanize %>
              </h3>
              <%= render "shared/badge", color: case decision_log.decision_type
                when "recommendation_approved" then "success"
                when "recommendation_rejected" then "error"
                when "action_dismissed" then "warning"
                when "manual_override" then "info"
                else nil
              end do %>
                <%= decision_log.decision_type.humanize %>
              <% end %>
            </div>

            <% if decision_log.reference.present? %>
              <p class="text-xs text-secondary mt-1">
                <%= t(".reference", type: decision_log.reference_type, id: decision_log.reference_id) %>
              </p>
            <% end %>
          </div>

          <div class="text-right shrink-0">
            <time class="text-xs text-secondary" datetime="<%= decision_log.created_at.iso8601 %>">
              <%= l(decision_log.created_at, format: :short) %>
            </time>
          </div>
        </div>

        <%# Rationale %>
        <% if decision_log.rationale.present? %>
          <div class="mt-3 p-3 bg-surface rounded-lg">
            <p class="text-sm text-primary"><%= decision_log.rationale %></p>
          </div>
        <% end %>

        <%# Actor %>
        <div class="flex items-center gap-2 mt-3">
          <%= icon "user", size: "xs", class: "text-secondary" %>
          <span class="text-xs text-secondary">
            <%= t(".by_actor", name: decision_log.actor.name) %>
          </span>
        </div>

        <%# Metadata (if present) %>
        <% if decision_log.metadata.present? && decision_log.metadata.any? %>
          <div class="mt-3 pt-3 border-t border-primary">
            <details class="group/details">
              <summary class="flex items-center gap-1 text-xs text-secondary cursor-pointer hover:text-primary transition-colors">
                <%= icon "chevron-right", size: "xs", class: "group-open/details:rotate-90 transition-transform" %>
                <%= t(".show_metadata") %>
              </summary>
              <div class="mt-2 pl-4 space-y-1">
                <% decision_log.metadata.each do |key, value| %>
                  <div class="flex items-center gap-2 text-xs">
                    <span class="text-secondary"><%= key.humanize %>:</span>
                    <span class="text-primary font-mono"><%= value %></span>
                  </div>
                <% end %>
              </div>
            </details>
          </div>
        <% end %>
      </div>

      <%# View Details Link %>
      <%= link_to decision_log_path(decision_log),
            data: { turbo_frame: :drawer },
            class: "shrink-0 p-2 rounded-lg text-secondary hover:text-primary hover:bg-subtle transition-colors self-center",
            title: t(".view_details") do %>
        <%= icon "arrow-right", size: "sm" %>
      <% end %>
    </div>
  </div>
<% end %>
