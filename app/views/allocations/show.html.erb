<% content_for :page_header do %>
  <div class="space-y-1 mb-6">
    <h1 class="text-xl lg:text-3xl font-medium text-primary">
      <%= t(".title") %>
    </h1>
    <p class="text-sm lg:text-base text-secondary">
      <%= t(".subtitle") %>
    </p>
  </div>
<% end %>

<% if @policy.blank? %>
  <div class="bg-container rounded-xl shadow-border-xs p-8 text-center">
    <%= icon "target", size: "xl", class: "mx-auto mb-4 text-secondary" %>
    <h2 class="text-lg font-medium text-primary mb-2"><%= t(".no_policy_title") %></h2>
    <p class="text-sm text-secondary mb-4"><%= t(".no_policy_description") %></p>
    <%= link_to t(".create_policy"), policy_versions_path, class: "inline-flex items-center justify-center gap-1.5 px-4 py-2 rounded-lg bg-primary text-white text-sm font-medium hover:bg-primary-dark transition-colors" %>
  </div>
<% elsif @total_value.zero? %>
  <div class="bg-container rounded-xl shadow-border-xs p-8 text-center">
    <%= icon "pie-chart", size: "xl", class: "mx-auto mb-4 text-secondary" %>
    <h2 class="text-lg font-medium text-primary mb-2"><%= t(".no_holdings_title") %>
    <p class="text-sm text-secondary"><%= t(".no_holdings_description") %></p>
  </div>
<% else %>
  <%# Total Portfolio Value %>
  <div class="bg-container rounded-xl shadow-border-xs p-6 mb-6">
    <p class="text-sm text-secondary mb-1"><%= t(".total_portfolio") %></p>
    <p class="text-3xl font-medium text-primary privacy-sensitive"><%= format_money(@total_value) %></p>
  </div>

  <%# Sleeve Allocation Table %>
  <div class="bg-container rounded-xl shadow-border-xs overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-divider">
      <h2 class="text-lg font-medium text-primary"><%= t(".allocation_table_title") %></h2>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-surface">
            <th class="px-6 py-3 text-left text-xs font-medium text-secondary uppercase tracking-wider"><%= t(".table.sleeve") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-secondary uppercase tracking-wider"><%= t(".table.target") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-secondary uppercase tracking-wider"><%= t(".table.current") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-secondary uppercase tracking-wider"><%= t(".table.gap") %></th>
            <th class="px-6 py-3 text-center text-xs font-medium text-secondary uppercase tracking-wider"><%= t(".table.status") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-divider">
          <% @sleeve_allocations.each do |allocation| %>
            <tr>
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <% if allocation[:sleeve].color.present? %>
                    <div class="w-3 h-3 rounded-full" style="background-color: <%= allocation[:sleeve].color %>"></div>
                  <% end %>
                  <span class="text-sm font-medium text-primary"><%= allocation[:sleeve].name %></span>
                </div>
              </td>
              <td class="px-6 py-4 text-right">
                <span class="text-sm text-secondary"><%= number_to_percentage(allocation[:target_pct], precision: 1) %></span>
              </td>
              <td class="px-6 py-4 text-right">
                <div>
                  <span class="text-sm font-medium text-primary"><%= number_to_percentage(allocation[:current_pct], precision: 1) %></span>
                  <span class="text-xs text-secondary ml-2 privacy-sensitive">(<%= format_money(allocation[:current_value]) %>)</span>
                </div>
                <%# Visual Bar %>
                <div class="mt-2 h-1.5 bg-surface-inset rounded-full overflow-hidden max-w-[150px] ml-auto">
                  <% target_width = [allocation[:target_pct], 100].min %>
                  <% current_width = [allocation[:current_pct], 100].min %>
                  <div class="h-full relative">
                    <div class="absolute inset-y-0 bg-secondary/30 rounded-full" style="width: <%= target_width %>%"></div>
                    <div class="absolute inset-y-0 rounded-full <%= allocation[:status] == :on_target ? 'bg-success' : allocation[:status] == :under_allocated ? 'bg-warning' : 'bg-destructive' %>" style="width: <%= current_width %>%"></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 text-right">
                <% gap_color = allocation[:dollar_gap] > 0 ? 'text-success' : allocation[:dollar_gap] < 0 ? 'text-destructive' : 'text-secondary' %>
                <span class="text-sm font-medium <%= gap_color %> privacy-sensitive">
                  <%= allocation[:dollar_gap] > 0 ? '+' : '' %><%= format_money(allocation[:dollar_gap]) %>
                </span>
              </td>
              <td class="px-6 py-4 text-center">
                <% status_config = allocation_status_config(allocation[:status]) %>
                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium <%= status_config[:class] %>">
                  <%= icon status_config[:icon], size: "xs" %>
                  <%= t(".status.#{allocation[:status]}") %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Unmapped Holdings Alert %>
  <% if @unmapped_holdings.any? %>
    <div class="bg-warning/10 border border-warning/20 rounded-xl p-6 mb-6">
      <div class="flex items-start gap-3">
        <%= icon "alert-triangle", size: "md", class: "text-warning shrink-0 mt-0.5" %>
        <div>
          <h3 class="text-sm font-medium text-primary mb-1"><%= t(".unmapped_title") %></h3>
          <p class="text-sm text-secondary mb-3"><%= t(".unmapped_description", count: @unmapped_holdings.count) %></p>
          <%= link_to t(".map_holdings"), instrument_mappings_path, class: "inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline" %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Account Breakdown %>
  <div class="bg-container rounded-xl shadow-border-xs p-6">
    <h2 class="text-lg font-medium text-primary mb-4"><%= t(".account_breakdown_title") %></h2>
    
    <% accounts = Current.family.accounts.active.assets.where("balance > 0") %>
    <% if accounts.any? %>
      <div class="space-y-4">
        <% accounts.each do |account| %>
          <div class="flex items-center justify-between p-4 bg-surface rounded-lg">
            <div class="flex items-center gap-3">
              <%= render "shared/account_icon", account: account %>
              <div>
                <p class="text-sm font-medium text-primary"><%= account.name %></p>
                <p class="text-xs text-secondary"><%= account.subtype&.humanize || account.accountable_type %></p>
              </div>
            </div>
            <p class="text-sm font-medium text-primary privacy-sensitive"><%= format_money(account.balance) %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-secondary"><%= t(".no_accounts") %></p>
    <% end %>
  </div>
<% end %>
